# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
SUPABASE_SERVICE_ROLE_KEY=ey...   # server-only, NEVER expose to client

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini           # cheap default; swap to gpt-4o for prod

# --- Resend (email) ---
RESEND_API_KEY=re_...
EMAIL_FROM="AI Audit Engine <reports@yourdomain.com>"
ADMIN_EMAIL=you@yourdomain.com

# --- Inngest (background jobs) ---
# Get these from https://app.inngest.com after connecting your app.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Admin dashboard ---
# Simple shared-secret to view /admin. Replace with proper Supabase auth in v2.
ADMIN_PASSWORD=changeme

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Optional: tech-detection providers (placeholders) ---
BUILTWITH_API_KEY=
WAPPALYZER_API_KEY=
