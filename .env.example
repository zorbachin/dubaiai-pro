# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit actual keys.

# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional — enables live web search via Perplexity Sonar
# Without this, the agent falls back to RSS feeds.
PERPLEXITY_API_KEY=pplx-...

# Optional — not used by default but available for future tool integrations
OPENAI_API_KEY=sk-...
