# --- Claude --------------------------------------------------------------
# Get your key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Default model used by the chat + agent runtime
ANTHROPIC_MODEL=claude-opus-4-7

# --- Obsidian vault ------------------------------------------------------
# Mission Control auto-saves every chat, goal, and journal entry into a
# folder called "Agentic OS" inside your Obsidian vault.
#
# Resolve your vault by id (recommended). Mission Control reads Obsidian's
# config (~/Library/Application Support/obsidian/obsidian.json on macOS,
# ~/.config/obsidian on Linux, %APPDATA%\obsidian on Windows) to find the
# vault path on disk.
OBSIDIAN_VAULT_ID=62b5a36e14d1ceef

# Or override the path directly (takes precedence over OBSIDIAN_VAULT_ID):
# OBSIDIAN_VAULT_PATH=/Users/you/Obsidian Vault

# Folder name created inside the vault (default: "Agentic OS")
# OBSIDIAN_AGENTIC_OS_FOLDER=Agentic OS
