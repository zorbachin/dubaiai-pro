#!/usr/bin/env python3
"""
dump — capture a raw brain-dump so nothing is ever lost.

This is the mechanical half of the `dump` skill: it saves the raw text to a
dated file and prints the path. The *thinking* half (parsing it into flywheel
content in the user's voice) is done by Claude via the `dump` skill — that's
where Opus reasoning lives. Keeping capture reliable here means the idea is
safe even before it's shaped.

Usage:
  dump "raw idea text…"            save a dump from the CLI
  echo "…" | dump                 save a dump from stdin
  dump --list                     list recent dumps
  dump --slug my-theme "text"     give it a memorable filename
"""

import os
import re
import subprocess
import sys
from datetime import datetime, timezone

ROOT = os.environ.get("CLAUDE_PROJECT_DIR") or subprocess.run(
    ["git", "rev-parse", "--show-toplevel"],
    capture_output=True, text=True).stdout.strip() or os.getcwd()
DUMPS = os.path.join(ROOT, ".claude", "os", "dumps")


def slugify(text, fallback="dump"):
    words = re.findall(r"[a-z0-9]+", text.lower())[:5]
    return "-".join(words) or fallback


def main(argv):
    if "--list" in argv:
        if not os.path.isdir(DUMPS):
            print("(no dumps yet)")
            return 0
        for f in sorted(os.listdir(DUMPS), reverse=True):
            print("  " + f)
        return 0

    slug = None
    if "--slug" in argv:
        i = argv.index("--slug")
        slug = argv[i + 1] if i + 1 < len(argv) else None
        argv = argv[:i] + argv[i + 2:]

    text = " ".join(argv).strip()
    if not text and not sys.stdin.isatty():
        text = sys.stdin.read().strip()
    if not text:
        print("dump: nothing to save (give text or pipe via stdin)", file=sys.stderr)
        return 1

    os.makedirs(DUMPS, exist_ok=True)
    date = datetime.now(timezone.utc).strftime("%Y-%m-%d")
    stamp = datetime.now(timezone.utc).strftime("%Y-%m-%d %H:%M UTC")
    slug = slug or slugify(text)
    path = os.path.join(DUMPS, f"{date}-{slug}.md")
    # If it exists, append a counter.
    n = 2
    while os.path.exists(path):
        path = os.path.join(DUMPS, f"{date}-{slug}-{n}.md")
        n += 1

    with open(path, "w", encoding="utf-8") as f:
        f.write(f"# Brain dump — {stamp}\n\n_Raw. Parse with the `dump` skill into "
                f"flywheel content; queue onto content-board.md._\n\n---\n\n{text}\n")

    print(f"🧠 dumped → {os.path.relpath(path, ROOT)}")
    print("   Next: I'll parse this into flywheel content in your voice.")
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
