 document.getElementById("ns").textContent="🎯 "+d.north_star;
 document.getElementById("meta").textContent="branch "+d.branch+" · "+d.totals.open+" open · "+d.totals.done+" done · "+d.updated;
 var g=d.ventures.map(function(v){
  var tasks=v.open.length?v.open.map(function(t){return '<div class=task><div><span class=tid>'+esc(t.id)+'</span>'+esc(t.title)+'</div>'+(t.need?'<div class=need>'+esc(t.need)+'</div>':'')+'</div>'}).join(''):'<div class=empty>clear ✓</div>';
  return '<div class=card style="--c:'+v.color+'"><h2>'+v.emoji+' '+esc(v.name)+'<span class=cnt>'+v.open.length+' open'+(v.done?' · <span class=done>'+v.done+' done</span>':'')+'</span></h2>'+tasks+'</div>';
