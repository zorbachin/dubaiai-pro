#!/usr/bin/env python3
"""
nucleus — the single context brain for everything you do with Claude.

One file is the source of truth: .claude/nucleus/NUCLEUS.md
Every Claude surface (Claude Code, chat, Cowork, design) can hand off context
TO it and pull context FROM it, so you never re-explain yourself between chats.

Self-running pieces (wired in .claude/settings.json):
  • SessionStart hook -> `nucleus load --hook`  (always injects the nucleus)
  • Stop hook         -> `nucleus sync --quiet`  (auto-writes a fresh handoff)

Manual / cross-surface use (copy/paste friendly):
  nucleus pull                 print the whole nucleus (paste into any chat)
  nucleus push "<note>"        add a handoff from anywhere  (--from chat|design|...)
  nucleus sync                 refresh the live git state block
  nucleus status               short one-screen summary
  nucleus brief                the "catch me up" digest for a fresh session
  nucleus init                 create the nucleus if it does not exist
  nucleus edit                 print the nucleus file path

Designed to be dependency-free: standard library only.
"""

import json
import os
import subprocess
import sys
from datetime import datetime, timezone

HANDOFFS_START = "<!-- HANDOFFS:START -->"
HANDOFFS_END = "<!-- HANDOFFS:END -->"
AUTOSTATE_START = "<!-- AUTOSTATE:START -->"
AUTOSTATE_END = "<!-- AUTOSTATE:END -->"

# Keep the auto-handoff log from growing forever.
MAX_HANDOFFS = 40


def repo_root():
    env = os.environ.get("CLAUDE_PROJECT_DIR")
    if env and os.path.isdir(env):
        return env
    try:
        out = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, check=True,
        )
        return out.stdout.strip()
    except Exception:
        return os.getcwd()


ROOT = repo_root()
NUCLEUS_DIR = os.path.join(ROOT, ".claude", "nucleus")
NUCLEUS = os.path.join(NUCLEUS_DIR, "NUCLEUS.md")


def now_iso():
    return datetime.now(timezone.utc).strftime("%Y-%m-%d %H:%M UTC")


def git(*args):
    try:
        out = subprocess.run(
            ["git", *args], cwd=ROOT, capture_output=True, text=True
        )
        return out.stdout.strip()
    except Exception:
        return ""


TEMPLATE = f"""# 🧠 Context Nucleus

> The single source of truth for everything you're doing with Claude — across
> chats, Cowork, code, and design. Any surface hands off context **to** this
> file; every new session reads context **from** it. If a fresh Claude doesn't
> have your context, it's because it hasn't read this yet — so it always does.

---

## 📌 North Star
_What we're ultimately building and why. Edit this by hand — it changes rarely._

- Project: **DubaiAI.pro** — premium landing page.
- Goal: (fill in the outcome you actually care about)

## 🎯 Active Threads
_What's in flight right now. The 1–5 things a new session should care about._

- [ ] (add the thing you're working on)

## 🧩 Decisions & Conventions
_Choices already made, so no surface re-litigates them._

- (e.g. "Brand color is #C8A45C", "Single-file index.html, no build step")

## 📥 Handoffs
_Newest first. Written automatically by hooks and by `nucleus push` from any
surface. This is the message-in-a-bottle between sessions._

{HANDOFFS_START}
{HANDOFFS_END}

## 🔄 Live State (auto)
_Refreshed automatically after each turn — do not edit by hand._

{AUTOSTATE_START}
_(no state captured yet — run `nucleus sync`)_
{AUTOSTATE_END}
"""


def ensure():
    """Create the nucleus from template if missing. Returns True if created."""
    if os.path.exists(NUCLEUS):
        return False
    os.makedirs(NUCLEUS_DIR, exist_ok=True)
    with open(NUCLEUS, "w", encoding="utf-8") as f:
        f.write(TEMPLATE)
    return True


def read():
    ensure()
    with open(NUCLEUS, "r", encoding="utf-8") as f:
        return f.read()


def write(text):
    os.makedirs(NUCLEUS_DIR, exist_ok=True)
    with open(NUCLEUS, "w", encoding="utf-8") as f:
        f.write(text)


def replace_block(text, start, end, new_inner):
    """Replace the content between two markers (markers preserved)."""
    if start not in text or end not in text:
        # Markers missing — append a fresh block at the end.
        return text.rstrip() + f"\n\n{start}\n{new_inner}\n{end}\n"
    pre, rest = text.split(start, 1)
    _, post = rest.split(end, 1)
    return f"{pre}{start}\n{new_inner}\n{end}{post}"


def get_block(text, start, end):
    if start in text and end in text:
        return text.split(start, 1)[1].split(end, 1)[0].strip()
    return ""


# ---------------------------------------------------------------- commands

def build_autostate():
    branch = git("rev-parse", "--abbrev-ref", "HEAD") or "(unknown)"
    last = git("log", "-1", "--pretty=%h %s — %cr") or "(no commits)"
    status = git("status", "--short")
    recent = git("log", "-5", "--pretty=%h %s (%cr)")
    diffstat = git("diff", "--stat", "HEAD")

    dirty = status.strip()
    dirty_block = dirty if dirty else "✓ clean — nothing uncommitted"

    lines = [
        f"- **When:** {now_iso()}",
        f"- **Branch:** `{branch}`",
        f"- **Last commit:** {last}",
        "",
        "**Working tree:**",
        "```",
        dirty_block,
        "```",
    ]
    if diffstat.strip():
        lines += ["", "**Uncommitted changes:**", "```", diffstat, "```"]
    if recent.strip():
        lines += ["", "**Recent commits:**", "```", recent, "```"]
    return "\n".join(lines)


def cmd_sync(quiet=False):
    text = read()
    text = replace_block(text, AUTOSTATE_START, AUTOSTATE_END, build_autostate())
    write(text)
    if not quiet:
        print("🔄 nucleus: live state refreshed")


def cmd_push(note, source="manual"):
    if not note.strip():
        print("nucleus: nothing to push (empty note)", file=sys.stderr)
        return 1
    text = read()
    inner = get_block(text, HANDOFFS_START, HANDOFFS_END)
    entry = f"### {now_iso()} · {source}\n{note.strip()}"

    existing = inner.strip()
    combined = entry + ("\n\n" + existing if existing else "")

    # Keep only the most recent MAX_HANDOFFS entries (newest first).
    entries = combined.split("\n\n### ")
    if len(entries) > MAX_HANDOFFS:
        entries = entries[:MAX_HANDOFFS]
    combined = "\n\n### ".join(entries)

    text = replace_block(text, HANDOFFS_START, HANDOFFS_END, combined)
    # Refresh live state too, so a push doubles as a checkpoint.
    text = replace_block(text, AUTOSTATE_START, AUTOSTATE_END, build_autostate())
    write(text)
    print(f"📥 nucleus: handoff captured from '{source}'")
    return 0


def cmd_pull():
    sys.stdout.write(read())


def cmd_load(hook=False):
    """Output for the SessionStart hook (JSON) or plain (interactive)."""
    body = read()
    if not hook:
        sys.stdout.write(body)
        return
    context = (
        "🧠 CONTEXT NUCLEUS — single source of truth for this user across "
        "Claude chats, Cowork, code, and design. Read it before asking the "
        "user to re-explain anything. After meaningful work, capture a handoff "
        "with `nucleus push \"...\"` (or it happens automatically on Stop).\n\n"
        + body
    )
    out = {
        "hookSpecificOutput": {
            "hookEventName": "SessionStart",
            "additionalContext": context,
        }
    }
    print(json.dumps(out))


def cmd_status():
    text = read()
    handoffs = get_block(text, HANDOFFS_START, HANDOFFS_END)
    count = handoffs.count("### ") if handoffs else 0
    branch = git("rev-parse", "--abbrev-ref", "HEAD") or "(unknown)"
    dirty = git("status", "--short")
    print("🧠 Context Nucleus")
    print(f"   file:     {os.path.relpath(NUCLEUS, ROOT)}")
    print(f"   branch:   {branch}")
    print(f"   handoffs: {count} captured")
    print(f"   tree:     {'dirty' if dirty.strip() else 'clean'}")
    latest = handoffs.split('### ', 1)[-1].splitlines()[0] if count else "—"
    print(f"   latest:   {latest}")


def cmd_brief():
    """A compact 'catch me up' digest — newest handoff + live state."""
    text = read()
    handoffs = get_block(text, HANDOFFS_START, HANDOFFS_END)
    state = get_block(text, AUTOSTATE_START, AUTOSTATE_END)
    print("# Catch-up brief\n")
    if handoffs.strip():
        latest = handoffs.split("\n\n### ")[0]
        print("## Latest handoff")
        print(latest if latest.startswith("###") else "### " + latest)
        print()
    print("## Live state")
    print(state or "(none)")


USAGE = __doc__


def main(argv):
    if not argv:
        cmd_status()
        return 0
    cmd = argv[0]
    rest = argv[1:]
    if cmd in ("-h", "--help", "help"):
        print(USAGE)
    elif cmd == "init":
        created = ensure()
        cmd_sync(quiet=True)
        print("✨ nucleus created" if created else "nucleus already exists")
    elif cmd == "load":
        cmd_load(hook="--hook" in rest)
    elif cmd == "pull":
        cmd_pull()
    elif cmd == "push":
        source = "manual"
        if "--from" in rest:
            i = rest.index("--from")
            source = rest[i + 1] if i + 1 < len(rest) else source
            rest = rest[:i] + rest[i + 2:]
        note = " ".join(rest)
        return cmd_push(note, source)
    elif cmd == "sync":
        cmd_sync(quiet="--quiet" in rest)
    elif cmd == "status":
        cmd_status()
    elif cmd == "brief":
        cmd_brief()
    elif cmd == "edit":
        print(NUCLEUS)
    else:
        print(f"nucleus: unknown command '{cmd}'\n", file=sys.stderr)
        print(USAGE, file=sys.stderr)
        return 2
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
