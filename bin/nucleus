<div class=panel><h3>Push to the brain</h3><textarea id=note placeholder="Capture a decision, idea, or update…"></textarea><button id=send>→ Push to nucleus</button></div>
</div></div>
<script>
function esc(s){return (s||"").replace(/&/g,"&amp;").replace(/</g,"&lt;")}
