#!/usr/bin/env python3
"""
nucleus — the single context brain for everything you do with Claude.

One file is the source of truth: .claude/nucleus/NUCLEUS.md
Every Claude surface (Claude Code, chat, Cowork, design) can hand off context
TO it and pull context FROM it, so you never re-explain yourself between chats.

Self-running pieces (wired in .claude/settings.json):
  • SessionStart hook -> `nucleus load --hook`  (always injects the nucleus)
  • Stop hook         -> `nucleus sync --quiet`  (auto-writes a fresh handoff)

Manual / cross-surface use (copy/paste friendly):
  nucleus pull                 print the whole nucleus (paste into any chat)
  nucleus push "<note>"        add a handoff from anywhere  (--from chat|design|...)
  nucleus sync                 refresh the live git state block
  nucleus status               short one-screen summary
  nucleus brief                the "catch me up" digest for a fresh session
  nucleus tasks                task ledger; auto-derives "done" from git/files
  nucleus task <id> <status>   set a task's status after checking its source
  nucleus serve [--port 4040]  HTTP bridge + command center so web apps (e.g.
                               localhost:3001) can read/push the nucleus.
                               Serves / (board), /command.json, /widget.js
  nucleus init                 create the nucleus if it does not exist
  nucleus edit                 print the nucleus file path

Designed to be dependency-free: standard library only.
"""

import json
import os
import subprocess
import sys
from datetime import datetime, timezone

HANDOFFS_START = "<!-- HANDOFFS:START -->"
HANDOFFS_END = "<!-- HANDOFFS:END -->"
AUTOSTATE_START = "<!-- AUTOSTATE:START -->"
AUTOSTATE_END = "<!-- AUTOSTATE:END -->"

# Keep the auto-handoff log from growing forever.
MAX_HANDOFFS = 40


def repo_root():
    env = os.environ.get("CLAUDE_PROJECT_DIR")
    if env and os.path.isdir(env):
        return env
    try:
        out = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, check=True,
        )
        return out.stdout.strip()
    except Exception:
        return os.getcwd()


ROOT = repo_root()


def nucleus_home():
    """Where the single nucleus lives.

    Set NUCLEUS_HOME to a shared path (e.g. ~/.claude/nucleus) and every repo
    AND every app (like the one on localhost:3001) points at the *same* file —
    making the nucleus truly singular across projects, not per-repo.
    """
    env = os.environ.get("NUCLEUS_HOME")
    if env:
        return os.path.expanduser(env)
    return os.path.join(ROOT, ".claude", "nucleus")


NUCLEUS_DIR = nucleus_home()
NUCLEUS = os.path.join(NUCLEUS_DIR, "NUCLEUS.md")


def now_iso():
    return datetime.now(timezone.utc).strftime("%Y-%m-%d %H:%M UTC")


def git(*args):
    try:
        out = subprocess.run(
            ["git", *args], cwd=ROOT, capture_output=True, text=True
        )
        return out.stdout.strip()
    except Exception:
        return ""


TEMPLATE = f"""# 🧠 Context Nucleus

> The single source of truth for everything you're doing with Claude — across
> chats, Cowork, code, and design. Any surface hands off context **to** this
> file; every new session reads context **from** it. If a fresh Claude doesn't
> have your context, it's because it hasn't read this yet — so it always does.

---

## 📌 North Star
_What we're ultimately building and why. Edit this by hand — it changes rarely._

- Project: **DubaiAI.pro** — premium landing page.
- Goal: (fill in the outcome you actually care about)

## 🎯 Active Threads
_What's in flight right now. The 1–5 things a new session should care about._

- [ ] (add the thing you're working on)

## 🧩 Decisions & Conventions
_Choices already made, so no surface re-litigates them._

- (e.g. "Brand color is #C8A45C", "Single-file index.html, no build step")

## 📥 Handoffs
_Newest first. Written automatically by hooks and by `nucleus push` from any
surface. This is the message-in-a-bottle between sessions._

{HANDOFFS_START}
{HANDOFFS_END}

## 🔄 Live State (auto)
_Refreshed automatically after each turn — do not edit by hand._

{AUTOSTATE_START}
_(no state captured yet — run `nucleus sync`)_
{AUTOSTATE_END}
"""


def ensure():
    """Create the nucleus from template if missing. Returns True if created."""
    if os.path.exists(NUCLEUS):
        return False
    os.makedirs(NUCLEUS_DIR, exist_ok=True)
    with open(NUCLEUS, "w", encoding="utf-8") as f:
        f.write(TEMPLATE)
    return True


def read():
    ensure()
    with open(NUCLEUS, "r", encoding="utf-8") as f:
        return f.read()


def write(text):
    os.makedirs(NUCLEUS_DIR, exist_ok=True)
    with open(NUCLEUS, "w", encoding="utf-8") as f:
        f.write(text)


def replace_block(text, start, end, new_inner):
    """Replace the content between two markers (markers preserved)."""
    if start not in text or end not in text:
        # Markers missing — append a fresh block at the end.
        return text.rstrip() + f"\n\n{start}\n{new_inner}\n{end}\n"
    pre, rest = text.split(start, 1)
    _, post = rest.split(end, 1)
    return f"{pre}{start}\n{new_inner}\n{end}{post}"


def get_block(text, start, end):
    if start in text and end in text:
        return text.split(start, 1)[1].split(end, 1)[0].strip()
    return ""


# ---------------------------------------------------------------- commands

def build_autostate():
    branch = git("rev-parse", "--abbrev-ref", "HEAD") or "(unknown)"
    last = git("log", "-1", "--pretty=%h %s — %cr") or "(no commits)"
    status = git("status", "--short")
    recent = git("log", "-5", "--pretty=%h %s (%cr)")
    diffstat = git("diff", "--stat", "HEAD")

    dirty = status.strip()
    dirty_block = dirty if dirty else "✓ clean — nothing uncommitted"

    lines = [
        f"- **When:** {now_iso()}",
        f"- **Branch:** `{branch}`",
        f"- **Last commit:** {last}",
        "",
        "**Working tree:**",
        "```",
        dirty_block,
        "```",
    ]
    if diffstat.strip():
        lines += ["", "**Uncommitted changes:**", "```", diffstat, "```"]
    if recent.strip():
        lines += ["", "**Recent commits:**", "```", recent, "```"]
    return "\n".join(lines)


def cmd_sync(quiet=False):
    text = read()
    text = replace_block(text, AUTOSTATE_START, AUTOSTATE_END, build_autostate())
    write(text)
    if not quiet:
        print("🔄 nucleus: live state refreshed")


def cmd_push(note, source="manual"):
    if not note.strip():
        print("nucleus: nothing to push (empty note)", file=sys.stderr)
        return 1
    text = read()
    inner = get_block(text, HANDOFFS_START, HANDOFFS_END)
    entry = f"### {now_iso()} · {source}\n{note.strip()}"

    existing = inner.strip()
    combined = entry + ("\n\n" + existing if existing else "")

    # Keep only the most recent MAX_HANDOFFS entries (newest first).
    entries = combined.split("\n\n### ")
    if len(entries) > MAX_HANDOFFS:
        entries = entries[:MAX_HANDOFFS]
    combined = "\n\n### ".join(entries)

    text = replace_block(text, HANDOFFS_START, HANDOFFS_END, combined)
    # Refresh live state too, so a push doubles as a checkpoint.
    text = replace_block(text, AUTOSTATE_START, AUTOSTATE_END, build_autostate())
    write(text)
    print(f"📥 nucleus: handoff captured from '{source}'")
    return 0


def cmd_pull():
    sys.stdout.write(read())


def cmd_load(hook=False):
    """Output for the SessionStart hook (JSON) or plain (interactive)."""
    body = read()
    if not hook:
        sys.stdout.write(body)
        return
    context = (
        "🧠 CONTEXT NUCLEUS — single source of truth for this user across "
        "Claude chats, Cowork, code, and design. Read it before asking the "
        "user to re-explain anything. After meaningful work, capture a handoff "
        "with `nucleus push \"...\"` (or it happens automatically on Stop).\n\n"
        + body
        + "\n\n---\n\n" + tasks_view(hook=True)
    )
    out = {
        "hookSpecificOutput": {
            "hookEventName": "SessionStart",
            "additionalContext": context,
        }
    }
    print(json.dumps(out))


def cmd_status():
    text = read()
    handoffs = get_block(text, HANDOFFS_START, HANDOFFS_END)
    count = handoffs.count("### ") if handoffs else 0
    branch = git("rev-parse", "--abbrev-ref", "HEAD") or "(unknown)"
    dirty = git("status", "--short")
    print("🧠 Context Nucleus")
    print(f"   file:     {os.path.relpath(NUCLEUS, ROOT)}")
    print(f"   branch:   {branch}")
    print(f"   handoffs: {count} captured")
    print(f"   tree:     {'dirty' if dirty.strip() else 'clean'}")
    latest = handoffs.split('### ', 1)[-1].splitlines()[0] if count else "—"
    print(f"   latest:   {latest}")


def build_brief():
    """A compact 'catch me up' digest — newest handoff + live state."""
    text = read()
    handoffs = get_block(text, HANDOFFS_START, HANDOFFS_END)
    state = get_block(text, AUTOSTATE_START, AUTOSTATE_END)
    out = ["# Catch-up brief\n"]
    if handoffs.strip():
        latest = handoffs.split("\n\n### ")[0]
        out.append("## Latest handoff")
        out.append(latest if latest.startswith("###") else "### " + latest)
        out.append("")
    out.append("## Live state")
    out.append(state or "(none)")
    return "\n".join(out)


def cmd_brief():
    print(build_brief())


# ------------------------------------------------- task ledger (derive, don't remember)
# Each task names the SOURCE OF TRUTH that proves it done, so status is derived
# from reality (git / Gmail / Calendar), not from anyone's memory. Locally
# checkable sources (git, files) auto-verify; Gmail/Calendar tasks are surfaced
# at session start with the exact check to run, then confirmed via `nucleus task`.

TASKS = os.path.join(NUCLEUS_DIR, "tasks.json")
TASK_ICON = {"done": "✅", "pending": "⬜", "scheduled": "🗓", "blocked": "⛔"}


def load_tasks():
    if not os.path.exists(TASKS):
        return []
    try:
        with open(TASKS, encoding="utf-8") as f:
            return json.load(f).get("tasks", [])
    except Exception:
        return []


def save_tasks(tasks):
    os.makedirs(NUCLEUS_DIR, exist_ok=True)
    with open(TASKS, "w", encoding="utf-8") as f:
        json.dump({"tasks": tasks}, f, indent=2, ensure_ascii=False)


def verify_git_task(check):
    """Derive done-ness for source==git from the repo/filesystem (fully local)."""
    if not check:
        return None
    if check.startswith("commit:"):
        return bool(git("rev-parse", "--verify", "--quiet", check.split(":", 1)[1]))
    if check.startswith("grep:"):
        _, pat, path = check.split(":", 2)
        try:
            with open(os.path.join(ROOT, path), encoding="utf-8") as f:
                return pat in f.read()
        except Exception:
            return False
    return os.path.exists(os.path.join(ROOT, check))


def reconcile_tasks():
    """Auto-verify everything locally checkable (git/files). Returns the list."""
    tasks = load_tasks()
    changed = False
    for t in tasks:
        if t.get("source") == "git":
            new = "done" if verify_git_task(t.get("check", "")) else "pending"
            if t.get("status") != new:
                t["status"], t["derived"] = new, True
                changed = True
    if changed:
        save_tasks(tasks)
    return tasks


def tasks_view(hook=False):
    tasks = reconcile_tasks()
    if not tasks:
        return "## ✅ Task ledger\n(none yet — add to .claude/nucleus/tasks.json)"
    todo = [t for t in tasks
            if t.get("source") in ("gmail", "calendar") and t.get("status") != "done"]
    lines = ["## ✅ Task ledger (derived from sources, not memory)"]
    for t in tasks:
        ic = TASK_ICON.get(t.get("status"), "•")
        d = " · derived" if t.get("derived") else ""
        lines.append(f"{ic} [{t.get('id','?')}] {t.get('title','?')} — {t.get('source','manual')}{d}")
        if t.get("note"):
            lines.append(f"     ↳ {t['note']}")
    out = "\n".join(lines)
    if hook and todo:
        out += ("\n\n⚠ RECONCILE NOW — before trusting memory or asking the user, verify these "
                "against the live source, then `nucleus task <id> <status>`:\n")
        for t in todo:
            out += f"  • [{t.get('id')}] {t.get('source')} → {t.get('check','(no check)')}\n"
    return out


def cmd_tasks():
    print(tasks_view())


def cmd_task(args):
    """`nucleus task <id> <status> [note...]` — set a task's status by hand."""
    if len(args) < 2:
        print("usage: nucleus task <id> <status> [note]", file=sys.stderr)
        return 2
    tid, status, note = args[0], args[1], " ".join(args[2:])
    tasks = load_tasks()
    for t in tasks:
        if t.get("id") == tid:
            t["status"] = status
            t.pop("derived", None)
            if note:
                t["note"] = note
            save_tasks(tasks)
            print(f"✅ task '{tid}' → {status}")
            return 0
    print(f"nucleus: no task with id '{tid}'", file=sys.stderr)
    return 1


def build_payload():
    """Everything a web app (e.g. localhost:3001) needs, as a dict."""
    text = read()
    return {
        "markdown": text,
        "brief": build_brief(),
        "handoffs": get_block(text, HANDOFFS_START, HANDOFFS_END),
        "state": get_block(text, AUTOSTATE_START, AUTOSTATE_END),
        "branch": git("rev-parse", "--abbrev-ref", "HEAD") or "(unknown)",
        "updated": now_iso(),
    }


# ------------------------------------------------- command center (board view)

# Status words the dashboard knows how to colour. Anything else renders neutral.
KNOWN_STATUS = {
    "active", "evaluating", "planned", "paused",  # connections
    "on", "manual", "off",                        # automations
}


def get_section(text, title_contains):
    """Return the body under the first '## ' heading containing title_contains.

    Stops at the next '## ' heading. Case-insensitive, emoji-tolerant.
    """
    out, capturing = [], False
    for line in text.splitlines():
        if line.startswith("## "):
            if capturing:
                break
            capturing = title_contains.lower() in line.lower()
            continue
        if capturing:
            out.append(line)
    return "\n".join(out).strip()


def parse_items(section):
    """Parse `- **Name** · status · note` bullets into dicts.

    Tolerant: status/note are optional and the `**` around the name is
    stripped. Non-bullet lines (blanks, the `_…_` legend) are skipped.
    """
    items = []
    for raw in section.splitlines():
        line = raw.strip()
        if not line.startswith("- "):
            continue
        parts = [p.strip() for p in line[2:].split(" · ")]
        name = parts[0].replace("**", "").strip()
        status, note, rest = "", "", parts[1:]
        if rest and rest[0].lower() in KNOWN_STATUS:
            status = rest[0].lower()
            note = " · ".join(rest[1:]).strip()
        else:
            note = " · ".join(rest).strip()
        if name:
            items.append({"name": name, "status": status, "note": note})
    return items


def parse_threads(section):
    """Parse `- [ ]` / `- [x]` checkbox bullets into {text, done} dicts."""
    out = []
    for raw in section.splitlines():
        line = raw.strip()
        low = line.lower()
        if low.startswith("- [ ]") or low.startswith("- [x]"):
            out.append({
                "text": line[5:].strip(),
                "done": low.startswith("- [x]"),
            })
    return out


def build_command():
    """Structured 'command center' board for the localhost:3001 app.

    Goals/threads/decisions are parsed from the hand-edited top of the
    nucleus; connections + automations come from their dedicated sections.
    Everything the command center renders lives in ONE file (the nucleus).
    """
    text = read()

    def strip_legend(section):
        # Drop the italic `_…_` helper line under each heading.
        keep = [ln for ln in section.splitlines()
                if not ln.strip().startswith("_")]
        return "\n".join(keep).strip()

    return {
        "northStar": strip_legend(get_section(text, "North Star")),
        "threads": parse_threads(get_section(text, "Active Threads")),
        "decisions": [
            l.strip()[2:].strip()
            for l in get_section(text, "Decisions").splitlines()
            if l.strip().startswith("- ")
        ],
        "connections": parse_items(get_section(text, "Connections")),
        "automations": parse_items(get_section(text, "Automations")),
        "brief": build_brief(),
        "branch": git("rev-parse", "--abbrev-ref", "HEAD") or "(unknown)",
        "updated": now_iso(),
    }


# Single-line embeddable widget. Any web app adds:
#   <script src="http://localhost:4040/widget.js"></script>
# ...and gets a floating 🧠 panel showing live context + a push box.
WIDGET_JS = r"""
(function () {
  var BASE = (document.currentScript && document.currentScript.src || "")
    .replace(/\/widget\.js.*$/, "") || "http://localhost:4040";
  var SRC = location.host || "web";
  function el(t, s, h) { var e = document.createElement(t); if (s) e.style.cssText = s; if (h != null) e.innerHTML = h; return e; }
  var btn = el("button", "position:fixed;right:18px;bottom:18px;z-index:99999;width:52px;height:52px;border-radius:50%;border:none;cursor:pointer;font-size:24px;background:#111;color:#C8A45C;box-shadow:0 4px 16px rgba(0,0,0,.3)", "🧠");
  var panel = el("div", "position:fixed;right:18px;bottom:80px;z-index:99999;width:360px;max-height:70vh;overflow:auto;display:none;background:#0d0d0f;color:#eee;border:1px solid #C8A45C;border-radius:12px;padding:14px;font:13px/1.5 system-ui,sans-serif;box-shadow:0 8px 32px rgba(0,0,0,.5)");
  var body = el("pre", "white-space:pre-wrap;word-break:break-word;margin:0 0 10px;color:#cfcfcf", "loading…");
  var ta = el("textarea", "width:100%;box-sizing:border-box;background:#1a1a1d;color:#fff;border:1px solid #333;border-radius:8px;padding:8px;resize:vertical;min-height:54px");
  ta.placeholder = "Push a handoff to the nucleus…";
  var send = el("button", "margin-top:8px;width:100%;padding:8px;border:none;border-radius:8px;background:#C8A45C;color:#111;font-weight:600;cursor:pointer", "→ Push to nucleus");
  var title = el("div", "font-weight:700;color:#C8A45C;margin-bottom:8px", "🧠 Context Nucleus");
  panel.appendChild(title); panel.appendChild(body); panel.appendChild(ta); panel.appendChild(send);
  function load() {
    fetch(BASE + "/nucleus.json").then(function (r) { return r.json(); })
      .then(function (d) { body.textContent = d.brief; })
      .catch(function () { body.textContent = "⚠ nucleus server not reachable at " + BASE + "\nRun: nucleus serve"; });
  }
  send.onclick = function () {
    var note = ta.value.trim(); if (!note) return;
    send.textContent = "…";
    fetch(BASE + "/push", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ note: note, from: SRC }) })
      .then(function () { ta.value = ""; send.textContent = "✓ pushed"; load(); setTimeout(function () { send.textContent = "→ Push to nucleus"; }, 1200); })
      .catch(function () { send.textContent = "✗ failed"; });
  };
  btn.onclick = function () { var open = panel.style.display === "none"; panel.style.display = open ? "block" : "none"; if (open) load(); };
  document.body.appendChild(btn); document.body.appendChild(panel);
})();
"""


# Status → accent colour for the dashboard chips.
STATUS_COLOR = {
    "active": "#2a9d8f", "on": "#2a9d8f",
    "evaluating": "#e09f3e", "manual": "#e09f3e",
    "planned": "#8a9aaa", "paused": "#c0563b", "off": "#c0563b",
}


def render_command_html(c):
    """Render build_command() as a brand-styled command-center page."""
    def esc(s):
        return (str(s).replace("&", "&amp;").replace("<", "&lt;")
                .replace(">", "&gt;"))

    def chip(status):
        if not status:
            return ""
        col = STATUS_COLOR.get(status, "#8a9aaa")
        return (f"<span style='display:inline-block;font-size:11px;"
                f"font-weight:600;letter-spacing:.3px;text-transform:uppercase;"
                f"color:{col};border:1px solid {col};border-radius:999px;"
                f"padding:1px 8px;margin-left:8px'>{esc(status)}</span>")

    def cards(items):
        if not items:
            return "<p style='color:#8a9aaa'>—</p>"
        rows = []
        for it in items:
            note = (f"<div style='color:#aeb8c4;margin-top:3px;font-size:13px'>"
                    f"{esc(it['note'])}</div>") if it.get("note") else ""
            rows.append(
                "<div style='background:#15151a;border:1px solid #243653;"
                "border-radius:10px;padding:12px 14px'>"
                f"<div><b style='color:#eef2f7'>{esc(it['name'])}</b>"
                f"{chip(it.get('status'))}</div>{note}</div>"
            )
        return ("<div style='display:grid;gap:10px;"
                "grid-template-columns:repeat(auto-fill,minmax(240px,1fr))'>"
                + "".join(rows) + "</div>")

    def threads(items):
        if not items:
            return "<p style='color:#8a9aaa'>—</p>"
        rows = []
        for t in items:
            box = "✅" if t["done"] else "⬜"
            col = "#8a9aaa" if t["done"] else "#eef2f7"
            rows.append(f"<li style='color:{col};margin:4px 0;list-style:none'>"
                        f"{box} {esc(t['text'])}</li>")
        return "<ul style='padding:0;margin:0'>" + "".join(rows) + "</ul>"

    def h(title):
        return (f"<h2 style='color:#C8A45C;font-size:15px;letter-spacing:.5px;"
                f"text-transform:uppercase;margin:30px 0 12px'>{title}</h2>")

    north = esc(c["northStar"]) or "—"
    return (
        "<!doctype html><meta charset=utf-8>"
        "<title>🎯 Command Center</title>"
        "<meta name='viewport' content='width=device-width,initial-scale=1'>"
        "<body style=\"background:radial-gradient(1200px 600px at 70% -10%,"
        "#14233f 0%,#0a1628 55%);color:#eef2f7;font:14px/1.6 system-ui,"
        "sans-serif;max-width:920px;margin:0 auto;padding:40px 22px 80px\">"
        "<div style='display:flex;justify-content:space-between;align-items:"
        "baseline;flex-wrap:wrap;gap:8px'>"
        "<h1 style='color:#C8A45C;font-size:26px;margin:0'>🎯 Command Center</h1>"
        f"<span style='color:#8a9aaa;font-size:13px'>branch <code>"
        f"{esc(c['branch'])}</code> · {esc(c['updated'])}</span></div>"
        + h("📌 North Star")
        + f"<div style='background:#15151a;border:1px solid #C8A45C;"
          f"border-radius:10px;padding:14px 16px;white-space:pre-wrap'>{north}</div>"
        + h("🎯 Active Threads") + threads(c["threads"])
        + h("🔌 Connections") + cards(c["connections"])
        + h("⚙️ Automations") + cards(c["automations"])
        + h("📥 Catch-up")
        + f"<pre style='background:#15151a;border:1px solid #243653;"
          f"border-radius:10px;padding:14px 16px;white-space:pre-wrap;"
          f"color:#cfd8e3'>{esc(c['brief'])}</pre>"
        "<script src='/widget.js'></script>"
    )


def cmd_serve(port=4040):
    import http.server
    import urllib.parse  # noqa: F401 (kept for clarity / future use)

    ensure()

    class Handler(http.server.BaseHTTPRequestHandler):
        def _cors(self):
            self.send_header("Access-Control-Allow-Origin", "*")
            self.send_header("Access-Control-Allow-Methods", "GET, POST, OPTIONS")
            self.send_header("Access-Control-Allow-Headers", "Content-Type")

        def _send(self, code, body, ctype="text/plain; charset=utf-8"):
            data = body.encode("utf-8") if isinstance(body, str) else body
            self.send_response(code)
            self.send_header("Content-Type", ctype)
            self.send_header("Content-Length", str(len(data)))
            self._cors()
            self.end_headers()
            self.wfile.write(data)

        def log_message(self, *a):
            pass  # quiet

        def do_OPTIONS(self):
            self.send_response(204)
            self._cors()
            self.end_headers()

        def do_GET(self):
            path = self.path.split("?", 1)[0]
            if path in ("/", "/index.html"):
                self._send(200, render_command_html(build_command()),
                           "text/html; charset=utf-8")
            elif path == "/raw":
                p = build_payload()
                html = (
                    "<!doctype html><meta charset=utf-8>"
                    "<title>Context Nucleus (raw)</title>"
                    "<body style='background:#0d0d0f;color:#eee;font:14px/1.6 "
                    "system-ui;max-width:780px;margin:40px auto;padding:0 20px'>"
                    "<h1 style='color:#C8A45C'>\U0001F9E0 Context Nucleus</h1>"
                    "<p>Branch <code>" + p["branch"] + "</code> · updated "
                    + p["updated"] + "</p><pre style='white-space:pre-wrap;"
                    "background:#15151a;padding:16px;border-radius:10px;"
                    "border:1px solid #C8A45C'>"
                    + p["markdown"].replace("&", "&amp;").replace("<", "&lt;")
                    + "</pre>"
                )
                self._send(200, html, "text/html; charset=utf-8")
            elif path == "/widget.js":
                self._send(200, WIDGET_JS, "application/javascript; charset=utf-8")
            elif path == "/command.json":
                self._send(200, json.dumps(build_command()),
                           "application/json; charset=utf-8")
            elif path == "/nucleus.json":
                self._send(200, json.dumps(build_payload()),
                           "application/json; charset=utf-8")
            elif path == "/nucleus.md":
                self._send(200, read(), "text/markdown; charset=utf-8")
            elif path == "/brief":
                self._send(200, build_brief())
            else:
                self._send(404, "not found")

        def do_POST(self):
            if self.path.split("?", 1)[0] != "/push":
                self._send(404, "not found")
                return
            length = int(self.headers.get("Content-Length", 0) or 0)
            raw = self.rfile.read(length).decode("utf-8") if length else "{}"
            try:
                data = json.loads(raw)
            except Exception:
                data = {}
            note = (data.get("note") or "").strip()
            source = (data.get("from") or "web").strip()
            if not note:
                self._send(400, json.dumps({"ok": False, "error": "empty note"}),
                           "application/json")
                return
            cmd_push(note, source)
            self._send(200, json.dumps({"ok": True, **build_payload()}),
                       "application/json")

    httpd = http.server.HTTPServer(("0.0.0.0", port), Handler)
    print(f"\U0001F9E0 nucleus serving on http://localhost:{port}")
    print(f"   command center : http://localhost:{port}/")
    print(f"   board feed     : http://localhost:{port}/command.json")
    print(f"   raw nucleus    : http://localhost:{port}/nucleus.json  (· /raw for markdown)")
    print(f"   embed widget   : <script src=\"http://localhost:{port}/widget.js\"></script>")
    print("   (Ctrl+C to stop)")
    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        print("\n\U0001F9E0 nucleus server stopped")


USAGE = __doc__


def main(argv):
    if not argv:
        cmd_status()
        return 0
    cmd = argv[0]
    rest = argv[1:]
    if cmd in ("-h", "--help", "help"):
        print(USAGE)
    elif cmd == "init":
        created = ensure()
        cmd_sync(quiet=True)
        print("✨ nucleus created" if created else "nucleus already exists")
    elif cmd == "load":
        cmd_load(hook="--hook" in rest)
    elif cmd == "pull":
        cmd_pull()
    elif cmd == "push":
        source = "manual"
        if "--from" in rest:
            i = rest.index("--from")
            source = rest[i + 1] if i + 1 < len(rest) else source
            rest = rest[:i] + rest[i + 2:]
        note = " ".join(rest)
        return cmd_push(note, source)
    elif cmd == "sync":
        cmd_sync(quiet="--quiet" in rest)
    elif cmd == "status":
        cmd_status()
    elif cmd == "brief":
        cmd_brief()
    elif cmd == "tasks":
        cmd_tasks()
    elif cmd == "task":
        return cmd_task(rest)
    elif cmd == "serve":
        port = 4040
        if "--port" in rest:
            i = rest.index("--port")
            if i + 1 < len(rest):
                port = int(rest[i + 1])
        cmd_serve(port)
    elif cmd == "edit":
        print(NUCLEUS)
    else:
        print(f"nucleus: unknown command '{cmd}'\n", file=sys.stderr)
        print(USAGE, file=sys.stderr)
        return 2
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
