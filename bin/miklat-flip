#!/usr/bin/env bash
# THE DOMAIN FLIP — run ONLY after miklatgames.fun DNS resolves to GitHub Pages.
# (Running early would 301 all live github.io links into a dead domain.)
set -e
cd "$(dirname "$0")/.."
echo "miklatgames.fun" > CNAME
# Iron Dome migration: every burned-in github.io URL -> the real domain
sed -i 's|https://zorbachin.github.io/dubaiai-pro/irondome/|https://miklatgames.fun/irondome/|g' irondome/index.html
sed -i 's|zorbachin.github.io/dubaiai-pro/irondome|miklatgames.fun/irondome|g' irondome/index.html
sed -i 's|https://zorbachin.github.io/dubaiai-pro/irondome/|https://miklatgames.fun/irondome/|g' content-assets/irondome-promo/PROMO-PACK.md
# cache-bust so installed PWAs pull the new share URLs
sed -i "s/irondome-v18/irondome-v19/" irondome/sw.js
sed -i "s/const GAME_VERSION = 'v18';/const GAME_VERSION = 'v19';/" irondome/index.html
echo "Flipped. Commit, push, merge — miklatgames.fun goes fully live."
