#!/usr/bin/env python3
"""
agentwatch — the free auto-dispatch loop for your AI Operating System.

Polls the agentbus for OPEN tasks assigned to local (free) agents, runs them on
a local Ollama instance, and writes the result back so the loop CLOSES — with
zero API cost. Paid agents (chatgpt/gemini) are intentionally NOT auto-run here;
they stay manual until you decide the spend is worth it.

Usage:
  agentwatch                 poll once, dispatch any open local-agent tasks, exit
  agentwatch --loop [--every 15]   keep polling every N seconds (the daemon)
  agentwatch --agents ollama,hermes  which agents to auto-run (default: ollama,hermes)
  agentwatch --dry-run       show what it WOULD dispatch, run nothing

Config via env:
  OLLAMA_HOST   default http://localhost:11434
  OLLAMA_MODEL  default llama3.2   (per-agent override: OLLAMA_MODEL_HERMES=...)
  AGENTWATCH_AGENTS  comma list, overridden by --agents

Design notes:
  • Dependency-free (urllib). Safe to run anywhere Python 3 + Ollama exist.
  • Idempotent: it claims a task before running, so two watchers won't double-run.
  • Never touches paid APIs. Free by construction.
  • If Ollama is unreachable, it blocks the task with a clear note instead of
    silently dropping it — the loop still registers a state.
"""

import json
import os
import subprocess
import sys
import time
import urllib.request
import urllib.error

ROOT = os.environ.get("CLAUDE_PROJECT_DIR") or subprocess.run(
    ["git", "rev-parse", "--show-toplevel"],
    capture_output=True, text=True).stdout.strip() or os.getcwd()
AGENTBUS = os.path.join(ROOT, "bin", "agentbus")

OLLAMA_HOST = os.environ.get("OLLAMA_HOST", "http://localhost:11434")
DEFAULT_MODEL = os.environ.get("OLLAMA_MODEL", "llama3.2")


def bus(*args):
    """Call agentbus and return (rc, stdout)."""
    r = subprocess.run([sys.executable, AGENTBUS, *args],
                       capture_output=True, text=True)
    return r.returncode, r.stdout.strip()


def open_tasks_for(agents):
    """Read the ledger directly for open tasks owned by the given agents."""
    # agentbus stores JSON; read it for structured access.
    rc, out = bus("list", "--status", "open")
    if rc != 0:
        return []
    # We need ids + titles + need; read the raw file for reliability.
    tasks_file = _tasks_file()
    if not os.path.exists(tasks_file):
        return []
    try:
        with open(tasks_file, encoding="utf-8") as f:
            db = json.load(f)
    except Exception:
        return []
    return [t for t in db.get("tasks", [])
            if t["status"] == "open" and t["owner"] in agents]


def _tasks_file():
    explicit = os.environ.get("TASKS_FILE")
    if explicit:
        return os.path.expanduser(explicit)
    home = os.environ.get("NUCLEUS_HOME")
    base = os.path.expanduser(home) if home else os.path.join(
        ROOT, ".claude", "nucleus")
    return os.path.join(base, "tasks.json")


def model_for(agent):
    # Per-agent model override, e.g. OLLAMA_MODEL_HERMES=openhermes
    override = os.environ.get(f"OLLAMA_MODEL_{agent.upper()}")
    if override:
        return override
    if agent == "hermes":
        return os.environ.get("OLLAMA_MODEL_HERMES", "openhermes")
    return DEFAULT_MODEL


def run_ollama(model, prompt):
    """Send a prompt to local Ollama. Returns text or raises."""
    body = json.dumps({"model": model, "prompt": prompt, "stream": False})
    req = urllib.request.Request(
        f"{OLLAMA_HOST}/api/generate",
        data=body.encode("utf-8"),
        headers={"Content-Type": "application/json"},
    )
    with urllib.request.urlopen(req, timeout=300) as resp:
        data = json.loads(resp.read().decode("utf-8"))
    return data.get("response", "").strip()


def dispatch(task, dry_run=False):
    tid = task["id"]
    agent = task["owner"]
    model = model_for(agent)
    prompt = task["title"]
    if task.get("need"):
        prompt += f"\n\nContext / requirements: {task['need']}"

    if dry_run:
        print(f"  [dry-run] {tid} → {agent} (ollama:{model}): {task['title']}")
        return

    print(f"  ▶ {tid} → {agent} (ollama:{model}): {task['title']}")
    bus("claim", tid, "--by", f"{agent}/watcher")
    try:
        result = run_ollama(model, prompt)
    except urllib.error.URLError as e:
        msg = f"Ollama unreachable at {OLLAMA_HOST} ({e}). Start it: `ollama serve`."
        bus("block", tid, "--by", f"{agent}/watcher", "--note", msg)
        print(f"  ▲ {tid} blocked — {msg}")
        return
    except Exception as e:
        bus("block", tid, "--by", f"{agent}/watcher", "--note", f"error: {e}")
        print(f"  ▲ {tid} blocked — {e}")
        return
    if not result:
        bus("block", tid, "--by", f"{agent}/watcher",
            "--note", "empty response from model")
        print(f"  ▲ {tid} blocked — empty response")
        return
    # Keep the receipt short; full output goes in the result field.
    bus("done", tid, "--by", f"{agent}/watcher", "--result", result)
    preview = result.replace("\n", " ")[:90]
    print(f"  ● {tid} done — {preview}{'…' if len(result) > 90 else ''}")


def poll_once(agents, dry_run=False):
    tasks = open_tasks_for(agents)
    if not tasks:
        return 0
    print(f"🔁 agentwatch: {len(tasks)} open task(s) for {', '.join(agents)}")
    for t in tasks:
        dispatch(t, dry_run=dry_run)
    return len(tasks)


def main(argv):
    agents = os.environ.get("AGENTWATCH_AGENTS", "ollama,hermes")
    loop = "--loop" in argv
    dry = "--dry-run" in argv
    every = 15
    if "--every" in argv:
        i = argv.index("--every")
        every = int(argv[i + 1]) if i + 1 < len(argv) else every
    if "--agents" in argv:
        i = argv.index("--agents")
        agents = argv[i + 1] if i + 1 < len(argv) else agents
    agent_list = [a.strip() for a in agents.split(",") if a.strip()]

    if not loop:
        n = poll_once(agent_list, dry_run=dry)
        if n == 0:
            print(f"✓ agentwatch: nothing open for {', '.join(agent_list)}")
        return 0

    print(f"🔭 agentwatch daemon — auto-running {', '.join(agent_list)} "
          f"on Ollama every {every}s. Ctrl+C to stop. (free, local)")
    try:
        while True:
            poll_once(agent_list, dry_run=dry)
            time.sleep(every)
    except KeyboardInterrupt:
        print("\n🔭 agentwatch stopped")
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
