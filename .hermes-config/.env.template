# Hermes Agent — Environment Template
# Copy this to ~/.hermes/.env and fill in your keys
# (The setup script does this automatically)

# =============================================================================
# LLM PROVIDER — pick ONE of the two options below
# =============================================================================

# OPTION A: OpenRouter (recommended — one key, access to all models)
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OPTION B: Direct Anthropic API
# Get key at: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=

# =============================================================================
# TELEGRAM GATEWAY — talk to Hermes from your phone
# =============================================================================
# Create a bot: open Telegram → @BotFather → /newbot
# Get your user ID: open @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=        # your Telegram user ID (numbers only)
TELEGRAM_HOME_CHANNEL=         # your chat ID with the bot (run /start, then check)

# =============================================================================
# SEARCH (optional but useful)
# =============================================================================
# EXA_API_KEY=                 # https://exa.ai — AI-native web search

# =============================================================================
# TIMEOUTS & SAFETY
# =============================================================================
TERMINAL_TIMEOUT=60
HERMES_HUMAN_DELAY_MODE=natural   # feels less robotic over Telegram
